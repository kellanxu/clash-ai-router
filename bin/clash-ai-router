#!/usr/bin/env python3
"""Install and inspect Clash AI Router for Clash Verge Rev."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import pathlib
import re
import shutil
import subprocess
import sys
import urllib.parse


APP_DIR = pathlib.Path(
    os.environ.get(
        "CLASH_VERGE_HOME",
        "~/Library/Application Support/io.github.clash-verge-rev.clash-verge-rev",
    )
).expanduser()
PROFILE_SCRIPT = pathlib.Path(__file__).resolve().parents[1] / "scripts" / "clash-ai-router.profile.js"
SOCKET = pathlib.Path(os.environ.get("MIHOMO_SOCKET", "/tmp/verge/verge-mihomo.sock"))


def fail(message: str) -> int:
    print(f"[ERR] {message}", file=sys.stderr)
    return 1


def ok(message: str) -> None:
    print(f"[OK] {message}")


def warn(message: str) -> None:
    print(f"[WARN] {message}")


def read_text(path: pathlib.Path) -> str:
    return path.read_text(encoding="utf-8")


def find_current_script(app_dir: pathlib.Path) -> pathlib.Path | None:
    profiles_yaml = app_dir / "profiles.yaml"
    if not profiles_yaml.exists():
        return None

    text = read_text(profiles_yaml)
    current = re.search(r"(?m)^current:\s*([^\s#]+)\s*$", text)
    if not current:
        return None

    current_uid = re.escape(current.group(1))
    current_block_match = re.search(
        rf"(?ms)^- uid:\s*{current_uid}\s*$.*?(?=^- uid:|\Z)", text
    )
    if not current_block_match:
        return None

    current_block = current_block_match.group(0)
    script_uid = re.search(r"(?m)^\s{4}script:\s*([^\s#]+)\s*$", current_block)
    if not script_uid:
        return None

    script_uid_re = re.escape(script_uid.group(1))
    script_block_match = re.search(
        rf"(?ms)^- uid:\s*{script_uid_re}\s*$.*?(?=^- uid:|\Z)", text
    )
    if not script_block_match:
        return None

    script_block = script_block_match.group(0)
    script_file = re.search(r"(?m)^\s{2}file:\s*(.+?)\s*$", script_block)
    if not script_file:
        return None

    return app_dir / "profiles" / script_file.group(1).strip()


def backup(path: pathlib.Path) -> pathlib.Path | None:
    if not path.exists():
        return None
    stamp = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
    backup_path = path.with_name(f"{path.name}.bak-{stamp}")
    shutil.copy2(path, backup_path)
    return backup_path


def install(args: argparse.Namespace) -> int:
    if not APP_DIR.exists():
        return fail(f"Clash Verge Rev 配置目录不存在：{APP_DIR}")
    if not PROFILE_SCRIPT.exists():
        return fail(f"找不到内置 profile script：{PROFILE_SCRIPT}")

    target = pathlib.Path(args.target).expanduser() if args.target else find_current_script(APP_DIR)
    if target is None:
        return fail(
            "没有在当前 Clash Verge Rev profile 里找到 script 插槽。"
            "可以手动把 scripts/clash-ai-router.profile.js 复制到 Profile Script。"
        )

    content = read_text(PROFILE_SCRIPT)
    print(f"目标脚本：{target}")
    if args.dry_run:
        print("dry-run：不会写入文件。")
        return 0

    target.parent.mkdir(parents=True, exist_ok=True)
    backup_path = backup(target)
    if backup_path:
        ok(f"已备份原脚本：{backup_path}")
    target.write_text(content, encoding="utf-8")
    ok("已安装 Clash AI Router profile script")
    print("下一步：在 Clash Verge Rev 里刷新当前订阅，然后运行 status 检查。")
    return 0


def curl_json(path: str, method: str = "GET", data: dict | None = None) -> dict | None:
    if not SOCKET.exists():
        return None
    cmd = [
        "curl",
        "-sS",
        "--unix-socket",
        str(SOCKET),
        "-X",
        method,
        "http://127.0.0.1" + path,
    ]
    if data is not None:
        cmd.extend(["-H", "Content-Type: application/json", "-d", json.dumps(data)])
    try:
        result = subprocess.run(cmd, check=False, capture_output=True, text=True)
    except FileNotFoundError:
        return None
    if result.returncode != 0 or not result.stdout.strip():
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return {"raw": result.stdout.strip()}


def status(_: argparse.Namespace) -> int:
    print(f"Clash Verge Rev 配置目录：{APP_DIR}")
    print(f"Mihomo socket：{SOCKET} ({'存在' if SOCKET.exists() else '不存在'})")

    script = find_current_script(APP_DIR)
    if script:
        print(f"当前 profile script：{script}")
        if script.exists():
            text = read_text(script)
            ok("profile script 可读取")
            print(f"包含 AI自动可用：{'是' if 'AI自动可用' in text else '否'}")
            has_ai_wrapper = "AI代理" in text or "AI住宅IP" in text
            print(f"包含 AI 兜底分组：{'是' if has_ai_wrapper else '否'}")
        else:
            warn("profiles.yaml 指向的 script 文件不存在")
    else:
        warn("没有识别到当前 profile 的 script 插槽")

    runtime = curl_json("/proxies")
    if not runtime or "proxies" not in runtime:
        warn("无法读取运行时分组；Clash 可能未运行，或 curl/socket 不可用")
        return 0

    groups = runtime["proxies"]
    expected_groups = ["AI自动可用", "国外自动可用", "普通国外"]
    for name in expected_groups:
        if name in groups:
            now = groups[name].get("now", "")
            choices = len(groups[name].get("all", []))
            ok(f"运行时分组存在：{name} -> {now}（候选 {choices} 个）")
        else:
            warn(f"运行时缺少分组：{name}")

    wrapper = next((name for name in ["AI代理", "AI住宅IP"] if name in groups), None)
    if wrapper:
        now = groups[wrapper].get("now", "")
        choices = len(groups[wrapper].get("all", []))
        ok(f"运行时 AI 兜底分组存在：{wrapper} -> {now}（候选 {choices} 个）")
    else:
        warn("运行时缺少 AI 兜底分组：AI代理 或 AI住宅IP")
    return 0


def select_auto(_: argparse.Namespace) -> int:
    runtime = curl_json("/proxies")
    proxies = runtime.get("proxies", {}) if runtime else {}
    group_name = "AI代理" if "AI代理" in proxies else "AI住宅IP"
    group = urllib.parse.quote(group_name, safe="")
    result = curl_json(f"/proxies/{group}", method="PUT", data={"name": "AI自动可用"})
    if result is None:
        return fail(f"无法设置 {group_name} -> AI自动可用；Clash 可能未运行")
    ok(f"已设置 {group_name} -> AI自动可用")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Clash AI Router helper")
    sub = parser.add_subparsers(dest="command", required=True)

    install_parser = sub.add_parser("install", help="安装 profile script 到当前 Clash Verge Rev profile")
    install_parser.add_argument("--dry-run", action="store_true", help="只显示将写入哪里，不实际修改")
    install_parser.add_argument("--target", help="手动指定 script 文件路径")
    install_parser.set_defaults(func=install)

    status_parser = sub.add_parser("status", help="检查本机安装和运行时状态")
    status_parser.set_defaults(func=status)

    select_parser = sub.add_parser("select-auto", help="把 AI代理 设置为 AI自动可用")
    select_parser.set_defaults(func=select_auto)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
